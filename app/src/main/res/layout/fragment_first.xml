<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="24dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- EditText para ingresar el monto en dólares -->
    <EditText
        android:id="@+id/editTextTransaction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ingrese monto en USD"
        android:inputType="numberDecimal"
        android:layout_marginBottom="16dp"/>

    <!-- Botón para Comprar -->
    <Button
        android:id="@+id/buttonBuy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Comprar"
        android:layout_marginBottom="8dp"/>

    <!-- Botón para Vender -->
    <Button
        android:id="@+id/buttonSell"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Vender"
        android:layout_marginBottom="16dp"/>

    <!-- Texto encabezado para el RecyclerView -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Historial de transacciones"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <!-- RecyclerView para mostrar todas las transacciones -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewTransactions"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
</LinearLayout>